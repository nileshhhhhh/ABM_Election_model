globals [
  supporters-A
  supporters-B
  supporters-undecided
]

turtles-own [
  age-group           ;; "18-45" or "45+"
  gender-group        ;; "Male" or "Female"
  edu-group           ;; "Grad" or "Non-Grad"

  support             ;; 0 = A, 1 = B, 2 = Undecided
  stubbornness
  pref-A
]

to setup
  clear-all
  validate-inputs

  create-turtles total-voters [
    setxy random-xcor random-ycor
    set age-group ""
    set gender-group ""
    set edu-group ""
    set support -1
    set stubbornness 0
    set pref-A 0.5
    set size 1.2
  ]

  assign-demographics-exact
  assign-initial-support-exact
  assign-preferences
  assign-stubbornness
  recolor-all

  reset-ticks
  update-results   ;; plots day 0 supporters
end

to go
  if ticks >= max-time [
    update-results
    show-results
    stop
  ]

  spread-support
  recolor-all
  tick
  update-results
end

to validate-inputs
  if age-18-45-count > total-voters [
    user-message "age-18-45-count cannot be greater than total-voters."
    stop
  ]
  if male-count > total-voters [
    user-message "male-count cannot be greater than total-voters."
    stop
  ]
  if grad-count > total-voters [
    user-message "grad-count cannot be greater than total-voters."
    stop
  ]
  if initial-A-count + initial-undecided-count > total-voters [
    user-message "initial-A-count + initial-undecided-count cannot be greater than total-voters."
    stop
  ]
end

to assign-demographics-exact
  ;; AGE
  ask n-of age-18-45-count turtles [
    set age-group "18-45"
  ]
  ask turtles with [age-group = ""] [
    set age-group "45+"
  ]

  ;; GENDER
  ask n-of male-count turtles [
    set gender-group "Male"
  ]
  ask turtles with [gender-group = ""] [
    set gender-group "Female"
  ]

  ;; EDUCATION
  ask n-of grad-count turtles [
    set edu-group "Grad"
  ]
  ask turtles with [edu-group = ""] [
    set edu-group "Non-Grad"
  ]
end

to assign-initial-support-exact
  ;; First assign exact A count
  ask n-of initial-A-count turtles [
    set support 0
  ]

  ;; Then assign exact Undecided count from remaining turtles
  ask n-of initial-undecided-count turtles with [support = -1] [
    set support 2
  ]

  ;; Remaining turtles automatically become B
  ask turtles with [support = -1] [
    set support 1
  ]
end

to assign-preferences
  ask turtles [
    let age-pref 0
    let gender-pref 0
    let edu-pref 0

    ;; Age contribution
    if age-group = "18-45" [ set age-pref prefA-age-18-45 ]
    if age-group = "45+"   [ set age-pref prefA-age-45plus ]

    ;; Gender contribution
    if gender-group = "Male"   [ set gender-pref prefA-male ]
    if gender-group = "Female" [ set gender-pref prefA-female ]

    ;; Education contribution
    if edu-group = "Grad"     [ set edu-pref prefA-grad ]
    if edu-group = "Non-Grad" [ set edu-pref prefA-non-grad ]

    ;; One-factor-at-a-time version:
    ;; For age-only experiments:
    set pref-A age-pref

    ;; If later you want gender-only, use:
    ;; set pref-A gender-pref

    ;; If later you want education-only, use:
    ;; set pref-A edu-pref

    if pref-A > 1 [ set pref-A 1 ]
    if pref-A < 0 [ set pref-A 0 ]
  ]
end

to assign-stubbornness
  ask turtles [
    set stubbornness base-stubbornness

    if stubbornness > 1 [ set stubbornness 1 ]
    if stubbornness < 0 [ set stubbornness 0 ]

    ;; undecided supporters are less stubborn
    if support = 2 [
      set stubbornness stubbornness * undecided-stubbornness-factor
    ]
  ]
end

to spread-support
  ask turtles [
    repeat contact-number [
      let target one-of other turtles
      if target != nobody [
        attempt-influence target
      ]
    ]
  ]
end

to attempt-influence [target]
  let my-support support

  ;; Undecided do not actively persuade others
  if my-support = 2 [ stop ]

  ;; If target already supports same candidate, do nothing
  if my-support = [support] of target [ stop ]

  let influence-prob persuasion-strength

  ;; similarity bonus across all three factors
  if age-group = [age-group] of target [
    set influence-prob influence-prob + same-age-bonus
  ]
  if gender-group = [gender-group] of target [
    set influence-prob influence-prob + same-gender-bonus
  ]
  if edu-group = [edu-group] of target [
    set influence-prob influence-prob + same-edu-bonus
  ]

  ;; undecided targets are easier to influence
  if [support] of target = 2 [
    set influence-prob influence-prob + undecided-openness
  ]

  ;; target's intrinsic preference matters
  if my-support = 0 [
    set influence-prob influence-prob + (preference-weight * [pref-A] of target)
  ]
  if my-support = 1 [
    set influence-prob influence-prob + (preference-weight * (1 - [pref-A] of target))
  ]

  ;; stubborn people are harder to change
  set influence-prob influence-prob - [stubbornness] of target

  if influence-prob > 1 [ set influence-prob 1 ]
  if influence-prob < 0 [ set influence-prob 0 ]

  if random-float 1 < influence-prob [
    ask target [
      set support my-support
    ]
  ]
end

to recolor-all
  ask turtles [
    if support = 0 [ set color red ]
    if support = 1 [ set color blue ]
    if support = 2 [ set color gray ]
  ]
end

to update-results
  set supporters-A count turtles with [support = 0]
  set supporters-B count turtles with [support = 1]
  set supporters-undecided count turtles with [support = 2]

  set-current-plot "Election Supporters Over Time"

  set-current-plot-pen "Supporters A"
  plot supporters-A

  set-current-plot-pen "Supporters B"
  plot supporters-B

  set-current-plot-pen "Undecided"
  plot supporters-undecided
end

to show-results
  show (word "Initial Supporters A: " initial-A-count)
  show (word "Initial Supporters B: " (total-voters - initial-A-count - initial-undecided-count))
  show (word "Initial Supporters Undecided: " initial-undecided-count)

  show (word "Supporters A at day " ticks ": " supporters-A)
  show (word "Supporters B at day " ticks ": " supporters-B)
  show (word "Supporters Undecided at day " ticks ": " supporters-undecided)
end

;; ---- Optional reporters for UI monitors ----

to-report initial-B-count
  report total-voters - initial-A-count - initial-undecided-count
end

to-report age-45plus-count
  report total-voters - age-18-45-count
end

to-report female-count
  report total-voters - male-count
end

to-report non-grad-count
  report total-voters - grad-count
end

to-report prefB-age-18-45
  report 1 - prefA-age-18-45
end

to-report prefB-age-45plus
  report 1 - prefA-age-45plus
end

to-report prefB-male
  report 1 - prefA-male
end

to-report prefB-female
  report 1 - prefA-female
end

to-report prefB-grad
  report 1 - prefA-grad
end

to-report prefB-non-grad
  report 1 - prefA-non-grad
end
